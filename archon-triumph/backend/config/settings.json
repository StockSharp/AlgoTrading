{
	"server": {
		"host": "127.0.0.1",
		"port": 8000,
		"reload": false
	},
	"logging": {
		"level": "INFO",
		"format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
		"file_rotation": "daily"
	},
	"application": {
		"name": "ARCHON TRIUMPH",
		"version": "1.0.0",
		"environment": "production"
	},
	"features": {
		"websocket_enabled": true,
		"auto_restart": true,
		"max_connections": 100
	}
}
