{
	"name": "archon-triumph",
	"version": "1.0.0",
	"description": "ARCHON TRIUMPH - Electron application with Python backend",
	"main": "electron/main.js",
	"scripts": {
		"start": "electron .",
		"dev": "NODE_ENV=development electron .",
		"build": "electron-builder",
		"build:linux": "electron-builder --linux",
		"build:win": "electron-builder --win",
		"build:mac": "electron-builder --mac",
		"postinstall": "electron-builder install-app-deps"
	},
	"keywords": [
		"electron",
		"archon",
		"triumph"
	],
	"author": "ARCHON TRIUMPH Team",
	"license": "MIT",
	"devDependencies": {
		"electron": "^28.0.0",
		"electron-builder": "^24.9.1"
	},
	"dependencies": {
		"ws": "^8.16.0"
	},
	"build": {
		"appId": "com.archon.triumph",
		"productName": "ARCHON TRIUMPH",
		"directories": {
			"output": "dist",
			"buildResources": "build"
		},
		"files": [
			"electron/**/*",
			"frontend/**/*",
			"backend/**/*",
			"package.json"
		],
		"linux": {
			"target": [
				"AppImage",
				"deb"
			],
			"category": "Utility"
		},
		"win": {
			"target": [
				"nsis",
				"portable"
			]
		},
		"mac": {
			"target": [
				"dmg",
				"zip"
			],
			"category": "public.app-category.utilities"
		}
	}
}
